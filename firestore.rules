rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Menú digital de Productos - Abierto para lectura y escritura en esta versión simplificada
    match /products/{productId} {
      allow read, write: if true;
    }

    // Insumos e Inventario crítico
    match /ingredients/{ingredientId} {
      allow read, write: if true;
    }

    // Pedidos de WhatsApp realizados por mesas o delivery
    match /orders/{orderId} {
      allow read, write: if true;
    }

    // Configuración general del local
    match /business_config/{configId} {
      allow read, write: if true;
    }
    
    // Fallback general
    match /{document=**} {
      allow read, write: if true;
    }
  }
}
